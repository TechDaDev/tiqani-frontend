# Django backend internal URL (server-to-server, never exposed to browser)
BACKEND_INTERNAL_URL=http://127.0.0.1:8000

# Optional direct browser fallback for legacy API helpers.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Next.js public site URL (used for absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Default locale for new visitors
NEXT_PUBLIC_DEFAULT_LOCALE=ar

# App name
NEXT_PUBLIC_APP_NAME=Tiqani

# Cookie/security behavior follows NODE_ENV.
NODE_ENV=development
